{
  "name": "maximeze",
  "version": "0.1.0",
  "private": true,
  "description": "Maximeze — modern minimalist cross-platform browser",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "dev:windows": "pnpm --filter @maximeze/windows tauri dev",
    "build:windows": "pnpm --filter @maximeze/windows tauri build",
    "build:design-system": "pnpm --filter @maximeze/design-system build",
    "build:core-engine": "pnpm --filter @maximeze/core-engine build"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.4.0"
  }
}
